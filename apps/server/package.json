    "cheerio": "^1.0.0",
    "dotenv": "^17.2.2",
    "hono": "^4.8.2",
    "qrcode": "^1.5.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@bookmark/config": "*",
    "@types/node": "^22.13.14",
    "tsdown": "^0.16.5",
    "tsx": "^4.19.2",
    "typescript": "^5"
