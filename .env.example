# Database (Turso or libsql)
# - File-based: file:./data/bookmarks.db
# - Turso local dev (when running `npm run db:local`): http://127.0.0.1:8080
# - Turso cloud: libsql://your-db.turso.io
DATABASE_URL=file:./data/bookmarks.db

# Required: password for API and web UI
APP_PASSWORD=your-secure-password

# Optional: WhatsApp session directory
WA_AUTH_DIR=./data/whatsapp_auth

# Optional: only save links from this WhatsApp group (group JID, e.g. 120363123456789012@g.us).
# Leave unset to save from all chats. To get the group JID: enable server logs and send a message
# in the group; the log will show remoteJid or add a temporary log of msg.key.remoteJid.
# WA_ALLOWED_GROUP_JID=120363123456789012@g.us

# Optional: CORS origin (defaults to * if unset)
# CORS_ORIGIN=https://your-app.fly.dev

# Optional: OpenRouter API key for AI features (summaries, tags, embeddings, smart search)
# Get yours at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...

# Optional: override default models (defaults shown below)
# OPENROUTER_CHAT_MODEL=google/gemini-2.5-flash-lite
# OPENROUTER_EMBEDDING_MODEL=google/gemini-embedding-001

# For local dev: point web app to the API (set in apps/web/.env or root)
# VITE_SERVER_URL=http://localhost:3000
