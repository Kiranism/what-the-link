{
  "extends": "@bookmark/config/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "@bookmark/ui/*": ["./src/*"],
      "@bookmark/components/ui/*": ["./src/components/*"],
      "@bookmark/components/reui/*": ["./src/components/reui/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules"]
}
